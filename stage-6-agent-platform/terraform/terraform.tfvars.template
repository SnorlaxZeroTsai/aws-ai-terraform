# Terraform variables template for Stage 6: AI Agent Platform
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control

# ============================================================================
# Basic Configuration
# ============================================================================

aws_region = "us-east-1"
environment = "prod"
platform_name = "ai-agent-platform"

# ============================================================================
# Docker Image Configuration
# ============================================================================

ecr_repository_name = "ai-agent-orchestrator"
image_tag = "latest"

# ============================================================================
# ECS Configuration
# ============================================================================

ecs_task_cpu = 512
ecs_task_memory = 1024
desired_count = 2
container_port = 8000

# Auto-scaling
enable_auto_scaling = true
min_capacity = 2
max_capacity = 10

# ============================================================================
# API Gateway Configuration
# ============================================================================

api_gateway_name = "ai-agent-platform-api"
api_gateway_stage_name = "v1"
api_gateway_throttling_burst_limit = 100
api_gateway_throttling_rate_limit = 50

# Custom Domain (optional)
# domain_name = "api.example.com"
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/abc123"

# ============================================================================
# Lambda Configuration
# ============================================================================

lambda_timeout = 30
lambda_memory_size = 256

# ============================================================================
# Authentication Configuration
# ============================================================================

# Auth type: "jwt", "api_key", or "cognito"
auth_type = "jwt"

# JWT Secret (use strong random string in production)
# Generate with: openssl rand -base64 32
jwt_secret = "CHANGE-THIS-IN-PRODUCTION-USE-STRONG-SECRET"

# Cognito User Pool ARN (if using Cognito auth)
# cognito_user_pool_arn = "arn:aws:cognito-idp:us-east-1:123456789012:userpool/us-east-1_abc123"

# ============================================================================
# Monitoring Configuration
# ============================================================================

enable_xray = true
enable_cloudwatch_alarms = true

# Alarm email (leave null to disable email notifications)
alarm_email = "alerts@example.com"

retention_days = 7

# ============================================================================
# Feature Flags
# ============================================================================

enable_chatbot_agent = true
enable_rag_agent = true
enable_autonomous_agent = true
enable_document_agent = true

# ============================================================================
# Cost Control
# ============================================================================

cost_allocation_tag = "ai-platform"

# ============================================================================
# Alarm Thresholds
# ============================================================================

api_5xx_threshold = 50
api_latency_threshold = 10000
ecs_cpu_threshold = 80
ecs_memory_threshold = 85

# ============================================================================
# VPC Configuration (Optional - will use Stage 1 VPC if not specified)
# ============================================================================

# vpc_config = {
#   subnet_ids = ["subnet-abc123", "subnet-def456"]
#   security_group_ids = ["sg-abc123"]
# }

# ============================================================================
# KMS Configuration (Optional)
# ============================================================================

# kms_key_arn = "arn:aws:kms:us-east-1:123456789012:key/abc123"

# ============================================================================
# Notes
# ============================================================================

# 1. Make sure all previous stages (1-5) are deployed
# 2. The terraform_remote_state data sources will fetch outputs from previous stages
# 3. S3 backend for Terraform state must be created before running terraform init
# 4. IAM permissions must be sufficient for all resources
